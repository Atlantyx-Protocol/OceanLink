# ============================================================
# Wallet keys
# ============================================================
# User key — used by /api/bridge to create HTLC orders.
PRIVATE_KEY_A=

# Liquidity Provider keys — required to run the matching engine
# with on-chain liquidity. Loaded by liquidityService.loadLPConfigsFromEnv().
# B → Ethereum Sepolia, C → Base Sepolia, D → Arbitrum Sepolia
PRIVATE_KEY_B=
PRIVATE_KEY_C=
PRIVATE_KEY_D=

# Admin key — used by the chain provider for read/observer ops.
PRIVATE_KEY_ADMIN=

# ============================================================
# RPC endpoints (required)
# ============================================================
SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# ============================================================
# Contract addresses (testnet defaults are baked into chains.ts;
# override here if you redeploy)
# ============================================================
# NEXT_PUBLIC_ prefix exposes these to the frontend bundle so backend and
# frontend share a single source of truth.
NEXT_PUBLIC_USDC_ADDRESS_SEPOLIA=
NEXT_PUBLIC_USDC_ADDRESS_ARBITRUM_SEPOLIA=
NEXT_PUBLIC_USDC_ADDRESS_BASE_SEPOLIA=

NEXT_PUBLIC_HTLC_ADDRESS_SEPOLIA=
NEXT_PUBLIC_HTLC_ADDRESS_ARBITRUM_SEPOLIA=
NEXT_PUBLIC_HTLC_ADDRESS_BASE_SEPOLIA=

# ============================================================
# Database
# ============================================================
# Used by backend for persisting orders, matches, executions.
# `make dev` boots a Postgres container with this exact URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/oceanlink

# ============================================================
# Backend tunables (all optional — defaults shown)
# ============================================================
TIME_LOCK=10                # HTLC timelock duration in minutes
MATCH_INTERVAL_MS=1000      # Matching engine tick interval
MATCH_THRESHOLD=0.3         # Minimum match-rate (0–1) to commit a cycle
LP_REFILL_INTERVAL_MS=10000 # How often LPs refill consumed orders

# ============================================================
# Server / CORS
# ============================================================
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000   # Set to your Vercel URL in prod
