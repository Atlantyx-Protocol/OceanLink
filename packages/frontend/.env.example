# Backend API base URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Network mode: "testnet" | "mainnet"
NEXT_PUBLIC_NETWORK_MODE=testnet

# Across Protocol
NEXT_PUBLIC_ACROSS_API_KEY=
NEXT_PUBLIC_ACROSS_INTEGRATOR_ID=0x00d9

# RPC endpoints (optional — falls back to chain default public RPCs)
NEXT_PUBLIC_ETHEREUM_RPC=
NEXT_PUBLIC_ARBITRUM_RPC=

# USDC contract addresses (must match backend's USDC_ADDRESS_* vars)
NEXT_PUBLIC_USDC_ADDRESS_SEPOLIA=
NEXT_PUBLIC_USDC_ADDRESS_ARBITRUM_SEPOLIA=
NEXT_PUBLIC_USDC_ADDRESS_BASE_SEPOLIA=
