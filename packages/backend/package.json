{
  "name": "@ocean-link/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist",
    "test": "tsx --test src/engine/matching/algorithm/algorithm.test.ts src/engine/matching/test/matching.test.ts src/engine/liquidity/liquidity.test.ts",
    "test:algorithm": "tsx --test src/engine/matching/algorithm/algorithm.test.ts",
    "test:matching": "tsx --test src/engine/matching/test/matching.test.ts",
    "test:liquidity": "tsx --test src/engine/liquidity/liquidity.test.ts",
    "bench:matching": "tsx scripts/bench-matching.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.2",
    "ethers": "^6.11.0",
    "fastify": "^4.25.2",
    "postgres": "^3.4.9",
    "viem": "^2.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.56.0",
    "pino-pretty": "^13.1.3",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
